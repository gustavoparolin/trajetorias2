{
  "name": "@trajetorias2/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "prisma migrate deploy && node prisma/seed-usuarios.mjs && node --import tsx src/index.ts",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed:usuarios": "node prisma/seed-usuarios.mjs",
    "db:importar": "node seed/importar-todos.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^7.0.0",
    "fastify": "^5.8.5",
    "prisma": "^5.22.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
