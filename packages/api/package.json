{
  "name": "@trajetorias2/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "prisma migrate deploy && prisma db seed && node src/index.js",
